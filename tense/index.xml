    <item>
      <title>verb</title>
      <link>https://trtrf.github.io/tense/verb/</link>
      <pubDate>Fri, 24 Apr 2026 00:00:00 +0000</pubDate>
      <guid>https://trtrf.github.io/tense/verb/</guid>
      <description>&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;Present /ˈprez.ənt/&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;Past /pɑːst/&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Tense /tens/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Present Tense&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Past Tense&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Participle /pɑːˈtɪs.ɪ.pəl/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Present participle (end in ing)&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Past participle (end in ed and en)&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;graph&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;state&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;-&amp;gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;横条+箭头:完成进行状态&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&amp;gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;箭头:进行状态&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;-&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;横条:完成状态&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;.&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;点:一般状态&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;p&gt;语态&lt;/p&gt;&#xA;&lt;p&gt;active:主动,主语是动作的执行者&lt;/p&gt;&#xA;&lt;p&gt;passive:被动,主语是动作的承受者&lt;/p&gt;&#xA;&lt;p&gt;被动语态的意义:&lt;/p&gt;&#xA;&lt;p&gt;1 关注结果不是过程&lt;/p&gt;&#xA;&lt;p&gt;2 强调动作的承受者:更关注动作而不是执行者 and 动作的执行者未知&lt;/p&gt;&#xA;&lt;p&gt;3 不想提及执行者&lt;/p&gt;&#xA;&lt;h1 id=&#34;联系verb&#34;&gt;联系verb&lt;/h1&gt;&#xA;&lt;p&gt;状态be&lt;/p&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;Present Tense&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;Present participle&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;Past Tense&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;Past participle&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;be&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;being&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;was and were&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;been&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;am&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;being&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;was&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;been&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;is&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;being&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;was&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;been&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;are&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;being&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;were&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;been&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;p&gt;表象 and 感官&lt;/p&gt;</description>
    </item>
