      <description>&lt;p&gt;学科&lt;/p&gt;&#xA;&lt;h1 id=&#34;politics&#34;&gt;politics&lt;/h1&gt;&#xA;&lt;h1 id=&#34;chemistry&#34;&gt;chemistry&lt;/h1&gt;&#xA;&lt;p&gt;soap /səʊp/ 肥皂;小苏打&lt;/p&gt;&#xA;&lt;h1 id=&#34;math&#34;&gt;math&lt;/h1&gt;&#xA;&lt;h1 id=&#34;geography&#34;&gt;geography&lt;/h1&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;left&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;right&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;非洲&lt;br /&gt;Africa /ˈæf.rɪ.kə/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;欧洲&lt;br /&gt;Europe /ˈjʊə.rəp/&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;Antarctica /ænˈtɑːk.tɪ.kə/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;南极洲&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;北美洲&lt;br /&gt;North America /nɔːθ/ /əˈmer.ɪ.kə/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;亚洲 &lt;br /&gt;Asia /ˈeɪ.ʒə/&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;南美洲&lt;br /&gt;South America /saʊθ/ /əˈmer.ɪ.kə/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;大洋洲     &lt;br /&gt;Oceania /əʊ.ʃiˈɑː.ni.ə/&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;h1 id=&#34;biology&#34;&gt;biology&lt;/h1&gt;&#xA;&lt;p&gt;food&lt;/p&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;carbohydrate  /ˌkɑː.bəʊˈhaɪ.dreɪt/&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;糖类;碳水化合物&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;rice /raɪs/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;米饭&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;millet /ˈmɪl.ɪt/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;小米&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;wheat /wiːt/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;小麦&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;barley /ˈbɑː.li/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;大麦&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;corn /kɔːn/&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;玉米&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;lipid  /ˈlɪp.ɪd/&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;脂质&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&gt;&#xA;  &lt;tbody&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;/td&gt;&#xA;          &lt;td style=&#34;text-align: center&#34;&gt;&lt;/td&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/tbody&gt;&#xA;&lt;/table&gt;&#xA;&lt;table&gt;&#xA;  &lt;thead&gt;&#xA;      &lt;tr&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;protein  /ˈprəʊ.tiːn/&lt;/th&gt;&#xA;          &lt;th style=&#34;text-align: center&#34;&gt;蛋白质&lt;/th&gt;&#xA;      &lt;/tr&gt;&#xA;  &lt;/thead&